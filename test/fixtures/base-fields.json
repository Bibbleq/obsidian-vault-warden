  {
    "name": "multi-type notetype with two bad entries produces one violation per bad entry",
    "base": {
      "version": 2,
      "fields": {
        "notetype": {
          "name": "notetype",
          "type": "multi",
          "required": true,
          "values": [
            "Good"
          ]
        }
      },
      "tags": {
        "max_depth": 2,
        "retired": []
      },
      "date_name_suffixes": [],
      "presence_only": []
    },
    "file": {
      "path": "Note.md",
      "frontmatter": {
        "notetype": [
          "Good",
          "Bad1",
          "Bad2"
        ],
        "created": "2026-07-13"
      }
    },
    "expect": [
      {
        "rule": "FM-NOTETYPE-INVALID",
        "field": "notetype",
        "found": "Bad1"
      },
      {
        "rule": "FM-NOTETYPE-INVALID",
        "field": "notetype",
        "found": "Bad2"
      }
    ]
  },
