[
  {
    "name": "ignored rule is suppressed while another rule still fires",
    "config": {
      "rules": {
        "CLASS-FIELD-MISSING": { "fix": "confirm" },
        "TAG-CASE": { "fix": "auto", "style": "pascal" }
      }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "title": { "type": "text", "required": true } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": {
        "class": "Widget",
        "validator_ignore": ["CLASS-FIELD-MISSING"],
        "tags": ["microsoft"]
      }
    },
    "expect": [{ "rule": "TAG-CASE", "field": "microsoft" }]
  },
  {
    "name": "bare string ignore value is accepted as a single-entry list",
    "config": {
      "rules": { "CLASS-FIELD-MISSING": { "fix": "confirm" } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "title": { "type": "text", "required": true } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": {
        "class": "Widget",
        "validator_ignore": "CLASS-FIELD-MISSING"
      }
    },
    "expect": []
  },
  {
    "name": "ignore list containing an unknown rule id is harmless",
    "config": {
      "rules": { "CLASS-FIELD-MISSING": { "fix": "confirm" } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "title": { "type": "text", "required": true } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": {
        "class": "Widget",
        "validator_ignore": ["NOT-A-REAL-RULE"]
      }
    },
    "expect": [{ "rule": "CLASS-FIELD-MISSING", "field": "title" }]
  },
  {
    "name": "custom ignore_key name is honored",
    "config": {
      "ignore_key": "skip_rules",
      "rules": { "CLASS-FIELD-MISSING": { "fix": "confirm" } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "title": { "type": "text", "required": true } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": {
        "class": "Widget",
        "skip_rules": ["CLASS-FIELD-MISSING"]
      }
    },
    "expect": []
  }
]
