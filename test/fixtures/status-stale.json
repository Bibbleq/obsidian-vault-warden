        "rule": "STATUS-STALE",
        "field": "status",
        "found": "Accepted",
        "expected": "Delivered",
        "mechanical": true,
        "suggested_fix": { "op": "set_field", "field": "status", "value": "Delivered" }
      }
    ]
  },
