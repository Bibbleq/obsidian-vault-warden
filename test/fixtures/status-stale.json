        "name": "SpeakingSession",
        "version": 1,
        "fields": {},
        "lifecycle": [
          { "date_field": "session_date", "when_status": ["Accepted", "Ready"], "suggest": "Delivered" }
        ]
      }
    },
    "today": "2026-07-13",
    "file": {
      "path": "Note.md",
      "frontmatter": {
        "class": "SpeakingSession",
        "status": "Accepted",
        "session_date": "2026-01-01",
        "created": "2026-07-01"
      }
    },
    "expect": [
