[
  {
    "name": "text field holding a number is a type violation",
    "config": { "rules": { "CLASS-FIELD-TYPE": { "fix": "none" } } },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "label": { "type": "text" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "label": 42 }
    },
    "expect": [{ "rule": "CLASS-FIELD-TYPE", "field": "label" }]
  },
  {
    "name": "text field holding a list is a type violation",
