[
  {
    "name": "date matching YYYY-MM-DD is clean",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DD"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-07-13" }
    },
    "expect": []
  },
  {
    "name": "datetime matching YYYY-MM-DDTHH:mm is clean",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DDTHH:mm"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-07-13T09:30" }
    },
    "expect": []
  },
  {
    "name": "space-separated datetime fails when only a T-separated format is configured",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DDTHH:mm"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-07-13 09:30" }
    },
    "expect": [{ "rule": "DATE-FORMAT", "field": "created" }]
  },
  {
    "name": "slash-separated date fails",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DD"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "13/07/2026" }
    },
    "expect": [{ "rule": "DATE-FORMAT", "field": "created" }]
  },
  {
    "name": "month out of range fails",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DD"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-13-01" }
    },
    "expect": [{ "rule": "DATE-FORMAT", "field": "created" }]
  },
  {
    "name": "hour out of range fails",
    "config": {
      "rules": { "DATE-FORMAT": { "fix": "auto", "formats": ["YYYY-MM-DDTHH:mm"] } }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-07-13T24:00" }
    },
    "expect": [{ "rule": "DATE-FORMAT", "field": "created" }]
  },
  {
    "name": "rule not configured produces no violation regardless of format",
    "config": { "rules": {} },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "13/07/2026" }
    },
    "expect": []
  },
  {
    "name": "value matching the second configured format is clean",
    "config": {
      "rules": {
        "DATE-FORMAT": {
          "fix": "auto",
          "formats": ["YYYY-MM-DD", "YYYY-MM-DDTHH:mm:ss"]
        }
      }
    },
    "classes": {
      "Widget": { "class": "Widget", "fields": { "created": { "type": "date" } } }
    },
    "file": {
      "path": "Widgets/Sprocket.md",
      "frontmatter": { "class": "Widget", "created": "2026-07-13T09:30:00" }
    },
    "expect": []
  }
]
