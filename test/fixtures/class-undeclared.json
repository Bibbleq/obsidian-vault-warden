[
  {
    "name": "note in a mapped folder without a class is a violation",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": { "Projects/Widgets": "Widget" }
    },
    "file": {
      "path": "Projects/Widgets/Note.md",
      "frontmatter": {}
    },
    "expect": [{ "rule": "CLASS-UNDECLARED", "field": "class", "expected": "Widget" }]
  },
  {
    "name": "note in a mapped folder with a class is clean",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": { "Projects/Widgets": "Widget" }
    },
    "file": {
      "path": "Projects/Widgets/Note.md",
      "frontmatter": { "class": "Widget" }
    },
    "expect": []
  },
  {
    "name": "note outside any mapped folder is clean",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": { "Projects/Widgets": "Widget" }
    },
    "file": {
      "path": "Random/Note.md",
      "frontmatter": {}
    },
    "expect": []
  },
  {
    "name": "nested folder mapping uses the deepest match",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": {
        "Projects": "Generic",
        "Projects/Widgets": "Widget"
      }
    },
    "file": {
      "path": "Projects/Widgets/Note.md",
      "frontmatter": {}
    },
    "expect": [{ "rule": "CLASS-UNDECLARED", "field": "class", "expected": "Widget" }]
  },
  {
    "name": "frontmatter null entirely is treated as no class declared",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": { "Projects/Widgets": "Widget" }
    },
    "file": {
      "path": "Projects/Widgets/Note.md",
      "frontmatter": null
    },
    "expect": [{ "rule": "CLASS-UNDECLARED", "field": "class", "expected": "Widget" }]
  },
  {
    "name": "subfolder of a mapped folder still matches",
    "config": {
      "rules": { "CLASS-UNDECLARED": { "fix": "auto" } },
      "class_locations": { "Projects/Widgets": "Widget" }
    },
    "file": {
      "path": "Projects/Widgets/Sub/Note.md",
      "frontmatter": {}
    },
    "expect": [{ "rule": "CLASS-UNDECLARED", "field": "class", "expected": "Widget" }]
  }
]
