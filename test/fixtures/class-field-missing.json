    "name": "required field absent produces a violation",
    "config": {
      "rules": { "CLASS-FIELD-MISSING": { "fix": "confirm" } }
    },
    "classes": {
      "Widget": {
        "class": "Widget",
        "fields": { "title": { "type": "text", "required": true } }
      }
    },
    "file": {
