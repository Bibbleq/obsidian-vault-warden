[
  {
    "name": "frontmatter null with empty base config produces only created-missing",
    "base": {
      "version": 2,
      "fields": {},
      "tags": {
        "max_depth": 2,
        "retired": []
      },
      "date_name_suffixes": [],
      "presence_only": []
    },
    "file": {
      "path": "Notes/Empty.md",
      "frontmatter": null
    },
    "expect": [
      {
        "rule": "CREATED-MISSING",
        "field": "created"
      }
    ]
  },
  {
    "name": "empty-string tag entry is skipped",
    "base": {
      "version": 2,
      "fields": {},
      "tags": {
        "max_depth": 2,
        "retired": []
      },
      "date_name_suffixes": [],
      "presence_only": []
    },
    "file": {
      "path": "Note.md",
      "frontmatter": {
        "tags": [
          "",
          "GoodTag"
        ],
        "created": "2026-07-13"
      }
    },
    "expect": []
  },
  {
    "name": "whitespace-only field value counts as empty not invalid",
    "base": {
      "version": 2,
      "fields": {
        "origin": {
          "name": "origin",
          "type": "select",
          "required": true,
          "values": [
            "manual"
          ]
        }
      },
      "tags": {
        "max_depth": 2,
        "retired": []
      },
      "date_name_suffixes": [],
      "presence_only": []
    },
    "file": {
      "path": "Note.md",
      "frontmatter": {
        "origin": "   ",
        "created": "2026-07-13"
      }
    },
    "expect": [
      {
        "rule": "FM-ORIGIN-MISSING",
        "field": "origin"
      }
    ]
  },
  {
    "name": "an everything-wrong note fires several violations at once",
    "base": {
      "version": 2,
      "fields": {
        "area": {
          "name": "area",
          "type": "select",
          "required": true,
          "values": [
            "IT Pro"
          ]
        },
        "notetype": {
          "name": "notetype",
          "type": "multi",
          "required": true,
          "values": [
            "Note"
          ]
        },
        "origin": {
          "name": "origin",
          "type": "select",
          "required": true,
          "values": [
            "manual"
          ]
        }
      },
      "tags": {
        "max_depth": 2,
        "retired": []
      },
      "date_name_suffixes": [
        "_date"
      ],
      "presence_only": []
    },
    "manifests": {},
    "file": {
      "path": "Everything.md",
      "frontmatter": {
        "area": "",
        "notetype": "Bogus",
        "origin": "nope",
        "tags": [
          "Bad_Tag",
          "microsoft"
        ],
        "review_date": "13-07-2026",
        "class": "Ghost"
      }
    },
    "expect": [
      {
        "rule": "FM-AREA-MISSING",
        "field": "area"
      },
      {
        "rule": "NOTETYPE-UNLISTED",
        "field": "notetype",
        "found": "Bogus"
      },
      {
        "rule": "FM-ORIGIN-INVALID",
        "field": "origin",
        "found": "nope"
      },
      {
        "rule": "TAG-FORMAT",
        "field": "tags"
      },
      {
        "rule": "TAG-CASE",
        "field": "tags"
      },
      {
        "rule": "DATE-FORMAT",
        "field": "review_date"
      },
      {
        "rule": "CREATED-MISSING",
        "field": "created"
      },
      {
        "rule": "CLASS-UNKNOWN",
        "field": "class",
        "found": "Ghost"
      }
    ]
  }
]
